@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h2 class="section-title">Hizmetlerimiz</h2>
        <p>Adenya Veteriner Kliniği olarak dostlarınız için kapsamlı hizmet sunuyoruz.</p>
    </div>

    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="service-card">
                <h4>💉 Aşı Takibi</h4>
                <p>Kedi, köpek ve diğer evcil dostlarınız için düzenli aşı planlaması yapılır.</p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="service-card">
                <h4>🩺 Genel Muayene</h4>
                <p>Hastalık teşhisi, rutin kontrol ve sağlık değerlendirmesi yapılır.</p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="service-card">
                <h4>🏥 Tedavi Takibi</h4>
                <p>Tedavi süreçleri kayıt altına alınır ve düzenli olarak takip edilir.</p>
            </div>
        </div>

    </div>

</div>