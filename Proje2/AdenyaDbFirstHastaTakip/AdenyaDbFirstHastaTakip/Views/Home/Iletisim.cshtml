@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h2 class="section-title">İletişim</h2>
        <p>Randevu ve bilgi almak için bizimle iletişime geçebilirsiniz.</p>
    </div>

    <div class="row">

        <div class="col-md-6">
            <div class="service-card">
                <h4>İletişim Bilgileri</h4>

                <p><strong>Adres:</strong> İstanbul / Türkiye</p>
                <p><strong>Telefon:</strong> 0555 000 00 00</p>
                <p><strong>Email:</strong> bilgi@adenyavet.com</p>
                <p><strong>Çalışma Saatleri:</strong> 09:00 - 18:00</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="service-card">
                <h4>Randevu Talep Formu</h4>

                <form>
                    <div class="mb-3">
                        <label>Ad Soyad</label>
                        <input class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Telefon</label>
                        <input class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Mesaj</label>
                        <textarea class="form-control"></textarea>
                    </div>

                    <button type="button" class="btn btn-success">
                        Gönder
                    </button>
                </form>
            </div>
        </div>

    </div>

</div>