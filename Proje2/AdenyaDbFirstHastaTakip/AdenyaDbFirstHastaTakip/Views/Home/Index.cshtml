@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<section class="hero">
    <div class="container text-center">

        <h1>Evcil Dostlarınızın Sağlığı Bizim Önceliğimiz</h1>

        <p class="mt-3 mb-4">
            Adenya Veteriner Kliniği ile aşı takibi, tedavi süreçleri
            ve veteriner hizmetleri tek noktada.
        </p>

        <a href="/Home/Iletisim" class="btn-main">
            Randevu Oluştur
        </a>

    </div>
</section>

<div class="container mt-5">

    <div class="text-center mb-5">
        <h2 class="section-title">Hizmetlerimiz</h2>
        <p>Evcil dostlarınız için profesyonel veteriner hizmetleri.</p>
    </div>

    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="service-card">
                <h4>💉 Aşı Takibi</h4>
                <p>
                    Düzenli aşı planlaması ve yaklaşan aşı bildirimleri.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="service-card">
                <h4>🩺 Muayene</h4>
                <p>
                    Genel sağlık kontrolleri ve detaylı muayene hizmetleri.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="service-card">
                <h4>🏥 Tedavi</h4>
                <p>
                    Hastalık teşhisi ve profesyonel tedavi süreçleri.
                </p>
            </div>
        </div>

    </div>

</div>

<div class="container mt-5">

    <div class="row">

        <div class="col-md-6">
            <h2 class="section-title">
                Neden Adenya Veteriner?
            </h2>

            <p>
                Uzman veteriner kadromuz ile evcil dostlarınıza
                modern ve güvenilir sağlık hizmetleri sunuyoruz.
            </p>

            <ul>
                <li>Uzman veteriner hekimler</li>
                <li>Modern ekipmanlar</li>
                <li>Aşı ve tedavi takibi</li>
                <li>Hızlı randevu sistemi</li>
            </ul>
        </div>

        <div class="col-md-6">
            <img src="https://images.unsplash.com/photo-1517849845537-4d257902454a"
                 class="img-fluid rounded shadow" />
        </div>

    </div>

</div>