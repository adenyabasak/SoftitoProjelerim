@model List<AdenyaDbFirstHastaTakip.Models.Veterinerler>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2>Veteriner Hekimler</h2>

    <form method="get">
        <div class="row mb-3">
            <div class="col-md-10">
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Ad, uzmanlık veya telefon ara..." />
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100">Ara</button>
            </div>
        </div>
    </form>

    <a href="/Veterinerler/Create" class="btn btn-success mb-3">
        Yeni Veteriner Hekim Ekle
    </a>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Ad Soyad</th>
                <th>Uzmanlık</th>
                <th>Telefon</th>
                <th>Email</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.AdSoyad</td>
                    <td>@item.Uzmanlik</td>
                    <td>@item.Telefon</td>
                    <td>@item.Email</td>
                    <td>
                        <a href="/Veterinerler/Edit/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                        <a href="/Veterinerler/Delete/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>