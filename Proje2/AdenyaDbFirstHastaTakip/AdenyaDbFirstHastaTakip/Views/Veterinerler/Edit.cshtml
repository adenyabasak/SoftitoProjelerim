@model AdenyaDbFirstHastaTakip.Models.Veterinerler

<div class="container mt-4">

    <h2>Veteriner Hekim Güncelle</h2>

    <form method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Ad Soyad</label>
            <input asp-for="AdSoyad" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Uzmanlık</label>
            <input asp-for="Uzmanlik" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Telefon</label>
            <input asp-for="Telefon" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Email" class="form-control" />
        </div>

        <button type="submit" class="btn btn-warning">Güncelle</button>
        <a href="/Veterinerler" class="btn btn-secondary">Geri Dön</a>

    </form>

</div>