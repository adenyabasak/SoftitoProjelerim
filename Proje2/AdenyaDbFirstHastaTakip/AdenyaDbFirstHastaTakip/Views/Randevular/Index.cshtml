@model List<AdenyaDbFirstHastaTakip.Models.Randevular>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2>Randevu Listesi</h2>

    <form method="get">
        <div class="row mb-3">
            <div class="col-md-10">
                <input type="text" name="search" value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Hayvan, veteriner veya durum ara..." />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">Ara</button>
            </div>
        </div>
    </form>

    <a href="/Randevular/Create" class="btn btn-success mb-3">Yeni Randevu Ekle</a>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Hayvan</th>
                <th>Veteriner</th>
                <th>Randevu Tarihi</th>
                <th>Durum</th>
                <th>Notlar</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Hayvan?.HayvanAdi</td>
                    <td>@item.Veteriner?.AdSoyad</td>
                    <td>@item.RandevuTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.RandevuDurumu</td>
                    <td>@item.Notlar</td>
                    <td>
                        <a href="/Randevular/Edit/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                        <a href="/Randevular/Delete/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>