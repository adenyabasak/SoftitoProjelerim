@model List<AdenyaDbFirstHastaTakip.Models.Sahipler>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2>Hasta Sahipleri</h2>

    <form method="get">
        <div class="row mb-3">

            <div class="col-md-10">
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Ad Soyad, Telefon veya Email Ara..." />
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    Ara
                </button>
            </div>

        </div>
    </form>

    <a href="/Sahipler/Create" class="btn btn-success mb-3">
        Yeni Sahip Ekle
    </a>

    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>ID</th>
                <th>Ad Soyad</th>
                <th>Telefon</th>
                <th>Email</th>
                <th>Adres</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.AdSoyad</td>
                    <td>@item.Telefon</td>
                    <td>@item.Email</td>
                    <td>@item.Adres</td>

                    <td>
                        <a href="/Sahipler/Edit/@item.Id"
                           class="btn btn-warning btn-sm">
                            Güncelle
                        </a>

                        <a href="/Sahipler/Delete/@item.Id"
                           class="btn btn-danger btn-sm">
                            Sil
                        </a>
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>