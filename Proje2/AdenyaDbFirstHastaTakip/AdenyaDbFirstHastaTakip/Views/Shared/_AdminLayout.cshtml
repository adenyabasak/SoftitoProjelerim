<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Adenya Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                background-color: #f4f6f9;
                font-family: 'Segoe UI', sans-serif;
            }

            .sidebar {
                width: 260px;
                min-height: 100vh;
                background: linear-gradient(180deg, #1f2937, #111827);
                position: fixed;
                left: 0;
                top: 0;
                padding: 25px 18px;
            }

            .sidebar h4 {
                color: white;
                font-weight: 700;
                margin-bottom: 5px;
            }

            .sidebar small {
                color: #9ca3af;
                display: block;
                margin-bottom: 25px;
            }

            .sidebar a {
                color: #d1d5db;
                text-decoration: none;
                display: block;
                padding: 12px 15px;
                border-radius: 10px;
                margin-bottom: 8px;
            }

            .sidebar a:hover {
                background-color: #374151;
                color: white;
            }

            .main-content {
                margin-left: 260px;
                padding: 25px;
            }

            .topbar {
                background-color: white;
                padding: 18px 25px;
                border-radius: 16px;
                margin-bottom: 25px;
                box-shadow: 0 4px 14px rgba(0,0,0,0.06);
            }

            .content-card {
                background-color: white;
                border-radius: 18px;
                padding: 25px;
                box-shadow: 0 4px 14px rgba(0,0,0,0.06);
            }
    </style>
</head>

<body>

    <div class="sidebar">
        <h4>Adenya Admin</h4>
        <small>Veteriner Hasta Takip Sistemi</small>

        <a href="/Admin">Dashboard</a>
        <a href="/Sahipler">Sahipler</a>
        <a href="/Hayvanlar">Hayvanlar</a>
        <a href="/Veterinerler">Veteriner Hekimler</a>
        <a href="/Tedaviler">Tedaviler</a>
        <a href="/Asilar">Aşı Takibi</a>
        <a href="/Randevular">Randevular</a>
        <a href="/Raporlar">Raporlar</a>
        <a href="/">User Sayfası</a>
    </div>

    <div class="main-content">

        <div class="topbar d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">Yönetim Paneli</h5>
                <small class="text-muted">Adenya Veteriner Klinik Sistemi</small>
            </div>

            <span class="badge bg-success">Admin</span>
        </div>

        <div class="content-card">
            @RenderBody()
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>