@model List<AdenyaDbFirstHastaTakip.Models.Hayvanlar>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container mt-4">

    <h2>Hayvan Listesi</h2>

    <form method="get">
        <div class="row mb-3">
            <div class="col-md-10">
                <input type="text" name="search" value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Hayvan adı, tür veya sahip ara..." />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">Ara</button>
            </div>
        </div>
    </form>

    <a href="/Hayvanlar/Create" class="btn btn-success mb-3">Yeni Hayvan Ekle</a>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Hayvan Adı</th>
                <th>Tür</th>
                <th>Irk</th>
                <th>Yaş</th>
                <th>Cinsiyet</th>
                <th>Sahip</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.HayvanAdi</td>
                    <td>@item.Tur</td>
                    <td>@item.Irk</td>
                    <td>@item.Yas</td>
                    <td>@item.Cinsiyet</td>
                    <td>@item.Sahip?.AdSoyad</td>
                    <td>
                        <a href="/Hayvanlar/Edit/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                        <a href="/Hayvanlar/Delete/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>