@model List<AdenyaDbFirstHastaTakip.Models.Tedaviler>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2>Tedavi Kayıtları</h2>

    <form method="get">
        <div class="row mb-3">
            <div class="col-md-10">
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Tedavi, hayvan veya veteriner ara..." />
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100">Ara</button>
            </div>
        </div>
    </form>

    <a href="/Tedaviler/Create" class="btn btn-success mb-3">
        Yeni Tedavi Ekle
    </a>

    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>Hayvan</th>
                <th>Veteriner</th>
                <th>Tedavi</th>
                <th>Tarih</th>
                <th>Ücret</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Hayvan?.HayvanAdi</td>

                    <td>@item.Veteriner?.AdSoyad</td>

                    <td>@item.TedaviAdi</td>

                    <td>
                        @item.TedaviTarihi.ToShortDateString()
                    </td>

                    <td>
                        @item.Ucret ₺
                    </td>

                    <td>
                        @if (item.OdendiMi)
                        {
                            <span class="badge bg-success">
                                Ödendi
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Ödenmedi
                            </span>
                        }
                    </td>

                    <td>
                        <a href="/Tedaviler/Edit/@item.Id"
                           class="btn btn-warning btn-sm">
                            Güncelle
                        </a>

                        <a href="/Tedaviler/Delete/@item.Id"
                           class="btn btn-danger btn-sm">
                            Sil
                        </a>
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>