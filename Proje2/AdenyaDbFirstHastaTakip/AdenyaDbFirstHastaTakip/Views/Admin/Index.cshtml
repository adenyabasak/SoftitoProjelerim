@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Dashboard</h2>

<div class="row">

    <div class="col-md-4 mb-3">
        <div class="card shadow border-0">
            <div class="card-body">
                <h6 class="text-muted">Toplam Sahip</h6>
                <h2>@ViewBag.SahipSayisi</h2>
                <a href="/Sahipler" class="btn btn-primary btn-sm">Detay</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow border-0">
            <div class="card-body">
                <h6 class="text-muted">Toplam Hayvan</h6>
                <h2>@ViewBag.HayvanSayisi</h2>
                <a href="/Hayvanlar" class="btn btn-primary btn-sm">Detay</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow border-0">
            <div class="card-body">
                <h6 class="text-muted">Veteriner Hekimler</h6>
                <h2>@ViewBag.VeterinerSayisi</h2>
                <a href="/Veterinerler" class="btn btn-primary btn-sm">Detay</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow border-0">
            <div class="card-body">
                <h6 class="text-muted">Tedavi Kayıtları</h6>
                <h2>@ViewBag.TedaviSayisi</h2>
                <a href="/Tedaviler" class="btn btn-primary btn-sm">Detay</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow border-0">
            <div class="card-body">
                <h6 class="text-muted">Aşı Kayıtları</h6>
                <h2>@ViewBag.AsiSayisi</h2>
                <a href="/Asilar" class="btn btn-primary btn-sm">Detay</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow border-0">
            <div class="card-body">
                <h6 class="text-muted">Randevular</h6>
                <h2>@ViewBag.RandevuSayisi</h2>
                <a href="/Randevular" class="btn btn-primary btn-sm">Detay</a>
            </div>
        </div>
    </div>

</div>